# Entorno y secretos
.env
conf.env
app/config/database.php

# Sesiones y logs de CI3 (archivos generados en runtime)
app/logs/*
!app/logs/index.html

# Caché de CI3
app/cache/*
!app/cache/index.html

# Archivos subidos por usuarios (imágenes de productos, XMLs de facturas)
uploads/*.jpg
uploads/*.jpeg
uploads/*.png
uploads/*.gif
uploads/*.webp
uploads/*.xml
uploads/*.pdf
uploads/thumbs/*.jpg
uploads/thumbs/*.jpeg
uploads/thumbs/*.png
uploads/thumbs/*.gif
uploads/thumbs/*.webp
!uploads/thumbs/no_image.jpg
!uploads/thumbs/no_image.png

# XMLs temporales generados
app/*/xmltemp/
files/temp/

# Certificados y llaves privadas (copiar manualmente al servidor)
*.p12
*.pem
*.key
*.pfx

# Composer
vendor/

# Editores e IDEs
.idea/
.vscode/
*.swp
*.swo

# Claude Code
.claude/

# OS
Thumbs.db
.DS_Store
desktop.ini

# Word temp files
~$*.docx
~$*.xlsx
node_modules/
.npm
dist/
!themes/default/assets/dist/
!themes/default/assets/dist/**/*.css
!themes/default/assets/dist/**/*.js
.phpunit.result.cache
